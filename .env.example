# Environment Variables Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to repository (it's in .gitignore)

# POSTGRESQL DATABASE
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_secure_db_password
POSTGRES_DB=vnpy

# REDIS
REDIS_PASSWORD=your_redis_password

# TELEGRAM NOTIFICATIONS
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Get your chat ID from @userinfobot on Telegram
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# BINANCE API (Start with TESTNET!)
# IMPORTANT: Never use production API keys in development
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_TESTNET=true

# TRADING CONFIGURATION
STARTING_CAPITAL=10
MAX_LEVERAGE=75
DAILY_LOSS_LIMIT=3
DEFAULT_STOP_LOSS=1.5
DEFAULT_TAKE_PROFIT=4
TRADING_SYMBOL=BTCUSDT
TRADING_INTERVAL=5

# VAULT SECRETS MANAGEMENT (Optional but Recommended)
# Using HashiCorp Vault for production secrets
# VAULT_ADDR=https://vault.yourdomain.com
# VAULT_TOKEN=s.vault.token.here

# ENCRYPTION KEYS (Auto-generated for development)
# FERNET_KEY=your_fernet_encryption_key_here

# API AUTHENTICATION
API_USERNAME=admin
API_PASSWORD=your_secure_password_here
AUTH_ENABLED=true

# SECURITY SETTINGS
SSL_VERIFY=true
SESSION_TIMEOUT=3600
LOG_SECURITY_EVENTS=true
SECURITY_LOG_LEVEL=INFO
CORS_ORIGIN=http://localhost:3000
# RATE_LIMIT=100  # Requests per minute
SESSION_SECRET=your_session_secret_key_here
JWT_SECRET=your_jwt_secret_key_here

# RATE LIMITING
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_PER_DAY=200

# REDIS CONNECTION (internal)
REDIS_HOST=redis
REDIS_PORT=6379

# POSTGRES CONNECTION (internal)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# MONITORING
PROMETHEUS_PORT=9091
METRICS_PORT=9091
GRAFANA_PASSWORD=admin

# ML SERVICES (optional)
# ML_ENABLED=false
# ML_MODEL_TYPE=ensemble
# ML_CONFIDENCE_THRESHOLD=0.6